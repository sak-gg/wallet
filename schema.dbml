Project wallet {
  database_type: 'MySQL'
}

Table wallets {
  id char(36) [pk]
  customer_id varchar(255) [not null, unique]
  balance bigint [not null, default: 0, note: 'CHECK (balance >= 0)']
  created_at datetime
  updated_at datetime
}

Table transactions {
  id char(36) [pk]
  wallet_id char(36) [not null, ref: > wallets.id]
  type varchar(16) [not null, note: "CHECK (type in ('topup','deduct'))"]
  amount bigint [not null, note: 'CHECK (amount > 0)']
  balance_after bigint [not null, note: 'CHECK (balance_after >= 0)']
  order_id varchar(255)
  created_at datetime

  indexes {
    (wallet_id, created_at) [name: 'idx_transactions_wallet_created']
    (wallet_id, order_id, type) [unique, name: 'uq_transactions_wallet_order']
  }
}
